{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/public/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "SCRAPEKIT_DATABASE_URL": "@scrapekit_database_url",
    "SCRAPEKIT_DIRECT_URL": "@scrapekit_direct_url",
    "SCRAPEKIT_API_KEY": "@scrapekit_api_key"
  }
}
