# ScrapeKit Colombia - Environment Variables
# Copy this file to .env.local and fill in real values (NEVER commit .env.local)

# Neon Postgres (pooled - runtime queries)
SCRAPEKIT_DATABASE_URL=postgresql://user:pass@host-pooler.region.aws.neon.tech/scrapekit?sslmode=require

# Neon Postgres (unpooled - migrations/DDL)
SCRAPEKIT_DIRECT_URL=postgresql://user:pass@host.region.aws.neon.tech/scrapekit?sslmode=require

# API key for protected write/index endpoints (choose any random string)
SCRAPEKIT_API_KEY=changeme-generate-a-random-secret

# Optional: default source adapter when not specified in request
# Values: colombia_camara | colombia_senado | dominicana_camara
SCRAPEKIT_DEFAULT_SOURCE=colombia_camara
